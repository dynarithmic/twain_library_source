#ifndef DTWAIN_CONFIG_H
#define DTWAIN_CONFIG_H

#define DTWAIN_BUILD_LOGCALLSTACK @DTWAIN_BUILD_LOGCALLSTACK@

#if defined(_DLL)
    #define DTWAIN_BUILD_NEEDVCRUNTIME 1
#else
    #define DTWAIN_BUILD_NEEDVCRUNTIME 0
#endif

#if DTWAIN_BUILD_LOGCALLSTACK == 1
    #define DTWAIN_BUILD_LOGGINGNAME "[Logging+]"
#else
    #define DTWAIN_BUILD_LOGGINGNAME ""
#endif

#if DTWAIN_BUILD_NEEDVCRUNTIME == 1
    #define DTWAIN_VCRUNTIME_BUILDNAME "[VC++]"
#else
    #define DTWAIN_VCRUNTIME_BUILDNAME ""
#endif

#define DTWAIN_VERINFO_PRODUCTVERSION  DTWAIN_VERINFO_FILEVERSION " Build " DTWAIN_BUILDVERSION " " DTWAIN_BUILD_LOGGINGNAME " " DTWAIN_VCRUNTIME_BUILDNAME

#endif
